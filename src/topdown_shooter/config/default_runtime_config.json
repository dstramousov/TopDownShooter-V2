{
  "window": {
    "title": "TopDownShooter V.2",
    "width": 1280,
    "height": 720,
    "target_fps": 60
  },
  "camera": {
    "zoom": 1.0,
    "clamp_to_map": true,
    "smooth_time": 0.18,
    "lookahead_tiles": 3.0,
    "min_zoom": 0.5,
    "max_zoom": 3.0,
    "zoom_step": 0.1,
    "move_speed_px_per_second": 720.0,
    "follow_player_by_default": true,
    "max_speed_px_per_second": 1800.0,
    "dead_zone_tiles": 1.25,
    "aim_lookahead_enabled": true,
    "aim_lookahead_tiles": 2.0
  },
  "player": {
    "marker_radius_px": 6,
    "movement_speed_px_per_second": 160.0,
    "collision_radius_px": 5,
    "max_health": 100
  },
  "debug_overlay": {
    "enabled_by_default": false,
    "panel_width": 1200,
    "padding": 18,
    "font_size": 8,
    "line_spacing": 6,
    "section_spacing": 12,
    "column_gap": 32,
    "label_width": 128,
    "background_alpha": 120,
    "font_path": "res/fonts/PressStart2P-Regular.ttf",
    "font_spacing": 0.0
  },
  "controls": {
    "quit": "KEY_ESCAPE",
    "debug_overlay": {
      "key": "KEY_D",
      "modifiers": [
        "KEY_LEFT_CONTROL",
        "KEY_RIGHT_CONTROL"
      ]
    },
    "camera_up": [
      "KEY_UP"
    ],
    "camera_down": [
      "KEY_DOWN"
    ],
    "camera_left": [
      "KEY_LEFT"
    ],
    "camera_right": [
      "KEY_RIGHT"
    ],
    "camera_zoom_in": "KEY_E",
    "camera_zoom_out": "KEY_Q",
    "camera_reset": "KEY_HOME",
    "camera_zoom_mouse_wheel": true,
    "player_up": [
      "KEY_W"
    ],
    "player_down": [
      "KEY_S"
    ],
    "player_left": [
      "KEY_A"
    ],
    "player_right": [
      "KEY_D"
    ],
    "camera_toggle_follow": "KEY_F",
    "fire_primary": "MOUSE_BUTTON_LEFT",
    "reload": "KEY_R",
    "weapon_slot_1": "KEY_ONE",
    "weapon_slot_2": "KEY_TWO",
    "weapon_slot_3": "KEY_THREE"
  },
  "aim_debug": {
    "enabled": true,
    "line_length_px": 140.0,
    "marker_radius_px": 4.0,
    "line_thickness_px": 2.0
  },
  "fps_counter": {
    "enabled": true,
    "position": "top_right",
    "margin_x": 12,
    "margin_y": 12,
    "font_size": 14
  },
  "weapons": {
    "database_path": "res/config/weapons.json"
  },
  "projectile_impacts": {
    "enabled": true,
    "lifetime_seconds": 0.16,
    "radius_px": 5.0
  },
  "hud": {
    "enabled": true,
    "position": "top",
    "margin_x": 12,
    "margin_y": 12,
    "padding": 8,
    "font_size": 16,
    "background_alpha": 150
  },
  "enemies": {
    "marker_radius_px": 6,
    "max_health": 100.0,
    "hit_marker_lifetime_seconds": 0.14,
    "hit_marker_radius_px": 8.0,
    "health_bar_visible_seconds": 1.6,
    "hit_flash_seconds": 0.12,
    "draw_view_cones": true,
    "vision_range_px": 320.0,
    "vision_angle_degrees": 80.0,
    "line_of_sight_sample_step_px": 8.0,
    "smart_initial_facing": true,
    "facing_candidate_step_degrees": 30.0,
    "facing_probe_side_angle_degrees": 25.0,
    "facing_wall_penalty_distance_px": 48.0,
    "facing_probe_step_px": 8.0,
    "min_squad_size": 3,
    "max_squad_size": 5,
    "squad_radius_px": 72.0,
    "min_enemy_spacing_px": 28.0,
    "max_initial_enemies": 30,
    "placement_attempts_per_enemy": 24,
    "chase_speed_px_per_second": 70.0,
    "preferred_combat_distance_px": 180.0,
    "minimum_combat_distance_px": 96.0,
    "combat_distance_tolerance_px": 40.0,
    "movement_direction_smoothing": 0.35,
    "approach_weight": 0.85,
    "strafe_weight": 0.55,
    "retreat_weight": 0.75,
    "strafe_switch_min_seconds": 0.9,
    "strafe_switch_max_seconds": 1.6
  }
}
