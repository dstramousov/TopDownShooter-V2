{
  "window": {
    "title": "TopDownShooter V.2",
    "width": 1280,
    "height": 720,
    "target_fps": 60
  },
  "camera": {
    "zoom": 1.0,
    "clamp_to_map": true,
    "smooth_time": 0.18,
    "lookahead_tiles": 3.0,
    "min_zoom": 0.5,
    "max_zoom": 3.0,
    "zoom_step": 0.1,
    "move_speed_px_per_second": 720.0,
    "follow_player_by_default": true,
    "max_speed_px_per_second": 1800.0,
    "dead_zone_tiles": 1.25,
    "aim_lookahead_enabled": true,
    "aim_lookahead_tiles": 2.0
  },
  "player": {
    "marker_radius_px": 6,
    "movement_speed_px_per_second": 160.0,
    "collision_radius_px": 5
  },
  "debug_overlay": {
    "enabled_by_default": false,
    "panel_width": 1200,
    "padding": 18,
    "font_size": 8,
    "line_spacing": 6,
    "section_spacing": 12,
    "column_gap": 32,
    "label_width": 128,
    "background_alpha": 120,
    "font_path": "res/fonts/PressStart2P-Regular.ttf",
    "font_spacing": 0.0
  },
  "controls": {
    "quit": "KEY_ESCAPE",
    "debug_overlay": {
      "key": "KEY_D",
      "modifiers": [
        "KEY_LEFT_CONTROL",
        "KEY_RIGHT_CONTROL"
      ]
    },
    "camera_up": [
      "KEY_UP"
    ],
    "camera_down": [
      "KEY_DOWN"
    ],
    "camera_left": [
      "KEY_LEFT"
    ],
    "camera_right": [
      "KEY_RIGHT"
    ],
    "camera_zoom_in": "KEY_E",
    "camera_zoom_out": "KEY_Q",
    "camera_reset": "KEY_HOME",
    "camera_zoom_mouse_wheel": true,
    "player_up": [
      "KEY_W"
    ],
    "player_down": [
      "KEY_S"
    ],
    "player_left": [
      "KEY_A"
    ],
    "player_right": [
      "KEY_D"
    ],
    "camera_toggle_follow": "KEY_F",
    "fire_primary": "MOUSE_BUTTON_LEFT"
  },
  "aim_debug": {
    "enabled": true,
    "line_length_px": 140.0,
    "marker_radius_px": 4.0,
    "line_thickness_px": 2.0
  },
  "fps_counter": {
    "enabled": true,
    "position": "top_right",
    "margin_x": 12,
    "margin_y": 12,
    "font_size": 14
  },
  "weapons": {
    "database_path": "res/config/weapons.json"
  }
}
